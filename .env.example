# ─────────────────────────────────────────────────────────────────────────────
# Event Manager – Environment Variables
# Copy this file to .env and fill in the values before running Docker Compose
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=eventmanager
DB_USER=emuser
DB_PASS=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters long (256-bit secret for HS256)
JWT_SECRET=change_me_replace_with_a_very_long_random_secret_string_at_least_32_chars
JWT_EXPIRATION_MS=86400000

# ── Spring Profile ────────────────────────────────────────────────────────────
# Use "dev" for development (create-drop schema, show SQL)
# Use "prod" (default) for production
SPRING_PROFILES_ACTIVE=prod
